{
  "name": "obsidian-soundboard",
  "version": "0.3.0",
  "description": "Play audio files from your vault in a soundboard.",
  "author": "João Gradim",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "lint": "eslint .",
    "test": "jest",
    "svelte-check": "svelte-check --tsconfig tsconfig.json",
    "changelog": "auto-changelog --package",
    "release-notes": "auto-changelog --template conventional -o release-notes.md",
    "version": "node version-bump.mjs && npm run changelog && git add CHANGELOG.md manifest.json versions.json"
  },
  "keywords": [],
  "license": "0-BSD",
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^22",
    "auto-changelog": "^2.5.0",
    "esbuild": "0.25.5",
    "esbuild-svelte": "^0.9.4",
    "eslint": "^9.39.2",
    "eslint-plugin-obsidianmd": "0.1.9",
    "eslint-plugin-svelte": "^3.15.0",
    "globals": "^14.0.0",
    "jest": "^30.2.0",
    "jiti": "2.6.1",
    "svelte": "^5.49.2",
    "svelte-check": "^4.3.6",
    "svelte-eslint-parser": "^1.4.1",
    "svelte-preprocess": "^6.0.3",
    "ts-jest": "^29.4.6",
    "tslib": "2.4.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.35.1"
  },
  "dependencies": {
    "obsidian": "latest"
  }
}
